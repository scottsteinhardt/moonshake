        date_str = iso_date(p["date"]) or ""
        meta_bits = [date_str] if date_str else []
        if p.get("description"): meta_bits.append(p["description"])
        line = f"- [{p['title']}]({BASE}/blog/{p['slug']}/)"
        if meta_bits: line += " — " + " — ".join(meta_bits)
        lines.append(line)
    lines += [
        "",
        "## Feeds", "",
        f"- [RSS]({BASE}/blog/feed.xml)",
        f"- [Sitemap]({BASE}/sitemap.xml)",
        "",
    ]
    if EMAIL:
        lines += ["## Contact", "", f"- Email: {EMAIL}", ""]
    return "\n".join(lines)


# ── Main ──────────────────────────────────────────────────────────────────────
def write_file(path: Path, content: str):
    if DRY:
        print(f"  [dry] would write {path} ({len(content)} bytes)")
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)

def copy_file(src: Path, dest: Path):
    if DRY:
        print(f"  [dry] would copy {src.name} -> {dest}")
        return
    dest.parent.mkdir(parents=True, exist_ok=True)
    if not dest.exists() or src.stat().st_mtime > dest.stat().st_mtime:
        shutil.copy2(src, dest)

def main():
    if not POSTS_DIR.exists():
        POSTS_DIR.mkdir(parents=True)
        print(f"created {POSTS_DIR} (empty)")

    existing = load_existing_posts()
    if existing:
        print(f"Found {len(existing)} existing HTML posts")

    print("Loading Markdown posts...")
    new_posts = load_markdown_posts()
    print(f"  {len(new_posts)} posts")

    rendered_new = 0
    image_copies = []

    for p in new_posts:
        slug     = p["slug"]
        post_dir = p["_md_file"].parent
        dt       = p["date"]

        if p.get("feature_image_src"):
            src = p["feature_image_src"]
            ym  = dt.strftime("%Y/%m") if dt else "unknown"
            dest = BLOG / "images" / "posts" / ym / slug / src.name
            image_copies.append((src, dest))
            p["feature_image_url"] = f"{BASE}/blog/images/posts/{ym}/{slug}/{src.name}"

        html_body = convert_markdown(p["_body_md"])
        html_body = process_images_in_html(html_body, post_dir, slug, dt, image_copies)
        p["_body_html_absolute"] = re.sub(r'(src|href)="(/[^"]+)"', r'\1="' + BASE + r'\2"', html_body)

        page_html = render_post_page(p, html_body)
        write_file(BLOG / slug / "index.html", page_html)
        print(f"  + {slug}  -> /blog/{slug}/")
        rendered_new += 1

    for src, dest in image_copies:
        copy_file(src, dest)

    by_slug = {p["slug"]: p for p in existing}
    for p in new_posts:
        by_slug[p["slug"]] = p
    all_posts = list(by_slug.values())

    print(f"Rebuilding blog index ({len(all_posts)} posts)...")
    write_file(BLOG / "index.html", render_blog_index(all_posts))
    print("Rebuilding feed.xml...")
    write_file(BLOG / "feed.xml", render_feed(all_posts))
    print("Rebuilding sitemap.xml...")
    write_file(SITE / "sitemap.xml", render_sitemap(all_posts))
    print("Rebuilding llms.txt...")
    write_file(SITE / "llms.txt", render_llms(all_posts))

    print()
    print(f"Done. Rendered {rendered_new} Markdown posts; {len(image_copies)} image copies; {len(all_posts)} total posts.")

    if not DRY:
        now      = datetime.now()
        zip_name = now.strftime("UPLOAD THIS AS OF %Y-%m-%d %-I:%M %p.zip")
        zip_path = SITE.parent / zip_name
        print(f"Zipping site -> {zip_path.name}")
        with zipfile.ZipFile(zip_path, "w", zipfile.ZIP_DEFLATED) as zf:
            for f in SITE.rglob("*"):
                if f.is_file():
                    zf.write(f, f.relative_to(SITE.parent))
        print(f"  {zip_path.stat().st_size // 1024:,} KB  ->  {zip_path}")


if __name__ == "__main__":
    main()
