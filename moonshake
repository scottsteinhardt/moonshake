def run_init():
    cwd = Path.cwd()
    config_path = cwd / "moonshake.toml"
    posts_path  = cwd / "posts"
    css_path    = cwd / "site" / "blog" / "assets" / "style.css"
    post_path   = posts_path / "hello-world.md"

    created = []
    skipped = []

    def scaffold(path: Path, content: str):
        if path.exists():
            skipped.append(path.name)
            return
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content)
        created.append(str(path.relative_to(cwd)))

    today = datetime.now().strftime("%Y-%m-%d")
    scaffold(config_path, STARTER_TOML)
    scaffold(post_path,   STARTER_POST.format(today=today))
    scaffold(css_path,    STARTER_CSS)

    print()
    print("Moonshake — new project setup")
    print("─" * 42)

    for f in created:
        print(f"  Created  {f}")
    for f in skipped:
        print(f"  Skipped  {f}  (already exists)")

    if created:
        print()
        print("Next steps:")
        print("  1. Open moonshake.toml and fill in your details")
        print("     (name, site URL, email, nav links)")
        print()
        if "moonshake.toml" in created:
            print("  2. If you have a newsletter, replace 'yourhandle' in [newsletter]")
            print("     with your Buttondown username — or delete that section entirely.")
            print()
        print("  3. Preview your first build:")
        print("       moonshake --dry")
        print()
        print("  4. Build your site:")
        print("       moonshake")
        print()
        print("  Your starter stylesheet is at site/blog/assets/style.css")
        print("  Customize the colors, fonts, and layout to make it your own.")
    else:
        print()
        print("Nothing new to create — project already exists.")

    print()
    print("Docs: https://github.com/scottsteinhardt/moonshake")
    print()


if ARGS.command == "init":
    run_init()
    sys.exit(0)


# ── Config ────────────────────────────────────────────────────────────────────
def load_config(path: str) -> dict:
    candidates = [Path(path), Path.home() / ".moonshake.toml"]
    for p in candidates:
        if p.exists():
            with open(p, "rb") as f:
                return tomllib.load(f)
    sys.exit(
        "Config not found. Tried:\n"
        + "\n".join(f"  {p}" for p in candidates)
        + "\n\nRun 'moonshake init' to set up a new project,"
        "\nor create a moonshake.toml manually."
    )

CFG = load_config(ARGS.config)

_paths  = CFG.get("paths",    {})
_blog   = CFG.get("blog",     {})
_author = CFG.get("author",   {})
_nav    = CFG.get("nav",      [])
