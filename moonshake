        f"Run 'moonshake init' to generate a starter stylesheet."
    )


# ── Nav builder ───────────────────────────────────────────────────────────────
def build_nav(post_page: bool) -> str:
    lines = ["<nav>"]
    for link in _nav:
        if link.get("post_only")  and not post_page: continue
        if link.get("index_only") and post_page:     continue
        href      = link.get("href",      "#")
        label     = link.get("label",     "")
