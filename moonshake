# ── Utilities ─────────────────────────────────────────────────────────────────
def slugify(s: str) -> str:
    s = s.lower()
    s = re.sub(r"[^\w\s-]", "", s)
    s = re.sub(r"[-\s]+", "-", s).strip("-")
    return s or "untitled"

def to_utc(d):
    if d is None: return None
    if isinstance(d, datetime):
        return d if d.tzinfo else d.replace(tzinfo=timezone.utc)
    if isinstance(d, date):
        return datetime(d.year, d.month, d.day, tzinfo=timezone.utc)
    if isinstance(d, str):
        try: return datetime.fromisoformat(d.replace("Z", "+00:00"))
        except ValueError: pass
        for fmt in ("%B %d, %Y", "%B %-d, %Y", "%Y-%m-%d"):
            try: return datetime.strptime(d, fmt).replace(tzinfo=timezone.utc)
            except ValueError: continue
    return None

def iso_date(dt): return dt.astimezone(timezone.utc).strftime("%Y-%m-%d") if dt else None
def iso_full(dt): return dt.astimezone(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S+00:00") if dt else None
def pretty_date(dt): return dt.strftime("%B %-d, %Y") if dt else ""
def rfc822(dt):      return format_datetime(dt.astimezone(timezone.utc)) if dt else ""


# ── Frontmatter parse ─────────────────────────────────────────────────────────
FM_RE = re.compile(r'^---\s*\n(.*?\n)---\s*\n?(.*)$', re.DOTALL)

def parse_frontmatter(text: str):
    m = FM_RE.match(text)
    if not m:
        return {}, text
    try:
        meta = yaml.safe_load(m.group(1)) or {}
    except yaml.YAMLError as e:
        print(f"  ! YAML error: {e}", file=sys.stderr)
        meta = {}
    return meta, m.group(2)


# ── Image resolver ────────────────────────────────────────────────────────────
def find_image(ref: str, post_dir: Path) -> Path | None:
    ref = re.sub(r'[?#].*$', '', ref).strip()
    if not ref or ref.startswith(("http://", "https://", "data:")):
        return None

    direct = post_dir / ref
    if direct.is_file():
        return direct.resolve()

    bare = Path(ref).name
    candidates = [
        post_dir / bare,
        post_dir / "images" / bare,
        POSTS_DIR.parent / "images" / bare,
    ]
    for c in candidates:
        if c.is_file():
            return c.resolve()

    for p in POSTS_DIR.rglob(bare):
        if p.is_file() and "node_modules" not in p.parts and ".obsidian" not in p.parts:
            return p.resolve()
    return None


# ── Body prep: expand wiki images + copy/rewrite ──────────────────────────────
WIKI_IMG = re.compile(r'!\[\[([^\]|]+?)(?:\|[^\]]*)?\]\]')

def expand_wiki_images(md: str) -> str:
    def sub(m):
        inner = m.group(0)[3:-2]
        parts = inner.split("|")
        file = parts[0].strip()
        alt  = parts[1].strip() if len(parts) > 1 else Path(file).stem
        return f'![{alt}]({file})'
    return WIKI_IMG.sub(sub, md)


def process_images_in_html(body_html: str, post_dir: Path, slug: str,
                            post_dt: datetime, copies: list) -> str:
    ym = post_dt.strftime("%Y/%m") if post_dt else "unknown"
    dest_rel = Path("images") / "posts" / ym / slug
    dest_abs = BLOG / dest_rel

    def rewrite(m):
        prefix, src = m.group(1), m.group(2)
        if src.startswith(("http://", "https://", "data:", "/")):
            return m.group(0)
        resolved = find_image(src, post_dir)
        if not resolved:
            print(f"  ! image not found: {src} (referenced in {slug})", file=sys.stderr)
            return m.group(0)
        out_name = resolved.name
        out_path = dest_abs / out_name
        copies.append((resolved, out_path))
        new_src = f"/blog/{dest_rel}/{out_name}".replace("\\", "/")
        return f'{prefix}"{new_src}"'

    return re.sub(r'(<img\s[^>]*src=)"([^"]+)"', rewrite, body_html)


