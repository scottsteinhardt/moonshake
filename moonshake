def render_sitemap(posts):
    posts_sorted = sorted(posts, key=lambda p: p["date"] or datetime.min.replace(tzinfo=timezone.utc), reverse=True)
    last = max((p["updated"] for p in posts if p["updated"]), default=datetime.now(timezone.utc))

    top_urls = []
    exclude_dirs  = {"archive", "blog", "images", "assets", "node_modules"}
    exclude_files = {"blog-posts.html"}
    seen = set()
    def add(u):
        if u not in seen: seen.add(u); top_urls.append(u)

    add("/")
    for p in sorted(SITE.glob("*.html")):
        if p.name in exclude_files or p.name == "index.html": continue
        add(f"/{p.name}")
    for d in sorted(SITE.iterdir()):
        if not d.is_dir() or d.name.startswith(".") or d.name in exclude_dirs: continue
        if (d / "index.html").exists():
            add(f"/{d.name}/")
        for sub in sorted(d.glob("*.html")):
            if sub.name == "index.html": continue
            add(f"/{d.name}/{sub.name}")

    parts = [
        '<?xml version="1.0" encoding="UTF-8"?>',
        '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">',
    ]
    for u in top_urls:
        priority = "1.0" if u == "/" else "0.8"
        parts.append(f'  <url>\n    <loc>{BASE}{u}</loc>\n    <changefreq>monthly</changefreq>\n    <priority>{priority}</priority>\n  </url>')
    parts.append(f'  <url>\n    <loc>{BASE}/blog/</loc>\n    <lastmod>{iso_date(last)}</lastmod>\n    <changefreq>weekly</changefreq>\n    <priority>0.9</priority>\n  </url>')
    for p in posts_sorted:
        parts.append(f'  <url>\n    <loc>{BASE}/blog/{p["slug"]}/</loc>\n    <lastmod>{iso_date(p["updated"])}</lastmod>\n    <changefreq>yearly</changefreq>\n    <priority>0.7</priority>\n  </url>')
    parts.append('</urlset>')
    return "\n".join(parts) + "\n"


