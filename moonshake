# ── Validate config ───────────────────────────────────────────────────────────
def cfg_require(val, key):
    if not val:
        sys.exit(f"Config error: {key} is required in moonshake.toml")

cfg_require(str(POSTS_DIR), "paths.posts")
cfg_require(str(SITE),      "paths.site")
cfg_require(BASE,           "blog.base_url")
cfg_require(TITLE,          "blog.title")
cfg_require(AUTHOR,         "blog.author")

css_file = SITE / CSS_URL.lstrip("/")
if not css_file.exists():
