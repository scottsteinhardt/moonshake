# ── Load existing HTML posts ───────────────────────────────────────────────────
def extract(pattern, text, group=1):
    m = re.search(pattern, text)
    return m.group(group) if m else None

def load_existing_posts():
    posts = []
    for idx in BLOG.glob("*/index.html"):
        slug = idx.parent.name
        if slug in NON_POSTS: continue
        t = idx.read_text()
        title = extract(r'<h2 class="post-title">([^<]+)</h2>', t) or slug
        title = html.unescape(title)
        desc  = html.unescape(extract(r'<meta name="description" content="([^"]+)"', t) or "")
        pub_iso = extract(r'<meta property="article:published_time" content="([^"]+)"', t)
        dt = to_utc(pub_iso) if pub_iso else None
        if not dt:
            vis = extract(r'<div class="date">([^<]+)</div>', t)
            dt = to_utc(vis) if vis else None
        og_img = extract(r'<meta property="og:image" content="([^"]+)"', t)
        if og_img == DEFAULT_OG:
            og_img = None
        posts.append({
            "slug":              slug,
            "title":             title,
            "description":       desc,
            "date":              dt,
            "feature_image_url": og_img,
            "updated":           dt,
            "tags":              [],
            "_source":           "existing",
        })
    return posts


# ── Load Markdown posts ───────────────────────────────────────────────────────
def load_markdown_posts():
    posts = []
    if not POSTS_DIR.exists():
        return posts
    for md_file in sorted(POSTS_DIR.rglob("*.md")):
        if md_file.name.startswith("_") or md_file.name.lower() == "readme.md":
            continue
        text = md_file.read_text()
        meta, body = parse_frontmatter(text)
        if meta.get("draft"):
            print(f"  - skip draft: {md_file.relative_to(POSTS_DIR)}")
            continue

        title = meta.get("title") or md_file.stem.replace("-", " ").replace("_", " ").title()
        slug  = meta.get("slug")  or slugify(
            md_file.stem if md_file.name != "index.md" else md_file.parent.name
        )
        dt      = to_utc(meta.get("date")) or datetime.fromtimestamp(md_file.stat().st_mtime, tz=timezone.utc)
        updated = to_utc(meta.get("updated")) or dt

        desc = (meta.get("description") or "").strip()
        if not desc:
            plain = re.sub(r"!\[\[[^\]]+\]\]|!\[[^\]]*\]\([^)]+\)", "", body)
            plain = re.sub(r"[#*_`>\[\]]+", "", plain).strip()
            first_para = re.split(r"\n\s*\n", plain, maxsplit=1)[0]
            desc = re.sub(r"\s+", " ", first_para)[:240]

        feature      = meta.get("feature_image")
        feature_path = None
        if feature:
            feature_path = find_image(str(feature), md_file.parent)
            if not feature_path:
                print(f"  ! feature_image not found for {slug}: {feature}", file=sys.stderr)

        tags = meta.get("tags") or []
        if isinstance(tags, str): tags = [tags]

        posts.append({
            "slug":              slug,
            "title":             title,
            "description":       desc,
            "date":              dt,
            "updated":           updated,
            "feature_image_src": feature_path,
            "tags":              list(tags),
            "_source":           "markdown",
            "_md_file":          md_file,
            "_body_md":          body,
        })
    return posts


